---
import Layout from "@components/Layout.astro";
import { getPropertiesPayload, getPropertyFacts } from "@lib/properties";

const payload = await getPropertiesPayload();
const facts = await getPropertyFacts();
const factsByProperty = new Map(facts.property_facts.map((fact) => [fact.property_id, fact]));
const explorerRows = payload.properties.map((property) => {
  const fact = factsByProperty.get(property.property_id);
  return {
    property_id: property.property_id,
    address: property.canonical_address,
    is_current: property.is_current,
    confidence_level: property.confidence_level,
    ward: property.ward || "Not listed",
    neighborhood: property.neighborhood || "Not listed",
    community: property.community || "Not listed",
    police_precinct: property.police_precinct || "Not listed",
    police_sector: property.police_sector || "Not listed",
    unit_count: property.estimated_unit_count,
    unit_count_confidence: property.unit_count_confidence || "Not listed",
    assessed_total_value: fact?.assessed_total_value ?? null,
    assessed_land_value: fact?.assessed_land_value ?? null,
    assessed_building_value: fact?.assessed_building_value ?? null
  };
});
const explorerJson = JSON.stringify(explorerRows).replace(/</g, "\\u003c");
---

<Layout title="Data Explorer | Minneapolis Public Housing Explorer" description="Interactive summaries of Minneapolis public housing property records by geography and metric.">
  <section class="border-b border-line bg-paper">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold">Data Explorer</h1>
      <p class="mt-2 max-w-3xl text-ink/70">
        Build quick summaries by ward, neighborhood, community, police geography, confidence, or unit-count basis.
      </p>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <label class="block">
          <span class="mb-1 block text-xs font-bold uppercase tracking-normal text-ink/55">Group By</span>
          <select class="w-full rounded border border-line bg-white px-4 py-3 text-base shadow-sm focus:shadow-focus" data-explorer-group>
            <option value="ward">Ward</option>
            <option value="community">Community</option>
            <option value="neighborhood">Neighborhood</option>
            <option value="police_precinct">Police precinct</option>
            <option value="police_sector">MPD sector</option>
            <option value="confidence_level">Confidence label</option>
            <option value="unit_count_confidence">Unit-count basis</option>
          </select>
        </label>
        <label class="block">
          <span class="mb-1 block text-xs font-bold uppercase tracking-normal text-ink/55">Metric</span>
          <select class="w-full rounded border border-line bg-white px-4 py-3 text-base shadow-sm focus:shadow-focus" data-explorer-metric>
            <option value="unit_count">Best unit count</option>
            <option value="property_count">Property count</option>
            <option value="assessed_total_value">Assessed total value</option>
            <option value="assessed_land_value">Assessed land value</option>
            <option value="assessed_building_value">Assessed building value</option>
            <option value="assessed_value_per_unit">Assessed value per unit</option>
          </select>
        </label>
        <label class="block">
          <span class="mb-1 block text-xs font-bold uppercase tracking-normal text-ink/55">Records</span>
          <select class="w-full rounded border border-line bg-white px-4 py-3 text-base shadow-sm focus:shadow-focus" data-explorer-scope>
            <option value="current">Current only</option>
            <option value="all">All records</option>
          </select>
        </label>
        <label class="block">
          <span class="mb-1 block text-xs font-bold uppercase tracking-normal text-ink/55">Unit Basis</span>
          <select class="w-full rounded border border-line bg-white px-4 py-3 text-base shadow-sm focus:shadow-focus" data-explorer-unit-basis>
            <option value="">All unit bases</option>
            <option value="reported">Reported</option>
            <option value="inferred">Inferred</option>
            <option value="unknown">Not listed</option>
          </select>
        </label>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <section>
          <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <h2 class="text-2xl font-bold">Ranked Summary</h2>
            <p class="text-sm font-semibold text-ink/60" data-explorer-status aria-live="polite"></p>
          </div>
          <div class="mt-4 overflow-x-auto rounded border border-line">
            <table class="min-w-full divide-y divide-line text-sm">
              <thead class="bg-paper text-left text-xs font-bold uppercase tracking-normal text-ink/60">
                <tr>
                  <th class="px-4 py-3">Group</th>
                  <th class="px-4 py-3">Properties</th>
                  <th class="px-4 py-3">Units</th>
                  <th class="px-4 py-3">Assessed Total</th>
                  <th class="px-4 py-3">Assessed / Unit</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-line bg-white" data-explorer-table></tbody>
            </table>
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold">Metric Bars</h2>
          <div class="mt-4 space-y-3" data-explorer-bars></div>
        </section>
      </div>
    </div>
  </section>

  <script is:inline type="application/json" id="explorer-data" set:html={explorerJson}></script>
  <script>
    type ExplorerRow = {
      property_id: string;
      address: string;
      is_current: boolean;
      confidence_level: string;
      ward: string;
      neighborhood: string;
      community: string;
      police_precinct: string;
      police_sector: string;
      unit_count: number | null;
      unit_count_confidence: string;
      assessed_total_value: number | null;
      assessed_land_value: number | null;
      assessed_building_value: number | null;
    };

    type Rollup = {
      group: string;
      properties: number;
      units: number;
      assessedTotal: number;
      assessedLand: number;
      assessedBuilding: number;
    };

    const dataElement = document.querySelector<HTMLScriptElement>("#explorer-data");
    const rows = JSON.parse(dataElement?.textContent || "[]") as ExplorerRow[];
    const groupSelect = document.querySelector<HTMLSelectElement>("[data-explorer-group]");
    const metricSelect = document.querySelector<HTMLSelectElement>("[data-explorer-metric]");
    const scopeSelect = document.querySelector<HTMLSelectElement>("[data-explorer-scope]");
    const unitBasisSelect = document.querySelector<HTMLSelectElement>("[data-explorer-unit-basis]");
    const tableBody = document.querySelector<HTMLTableSectionElement>("[data-explorer-table]");
    const bars = document.querySelector<HTMLElement>("[data-explorer-bars]");
    const status = document.querySelector<HTMLElement>("[data-explorer-status]");

    const numberFormatter = new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 });
    const currencyFormatter = new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
      maximumFractionDigits: 0
    });

    function metricValue(rollup: Rollup, metric: string): number {
      if (metric === "property_count") {
        return rollup.properties;
      }
      if (metric === "assessed_total_value") {
        return rollup.assessedTotal;
      }
      if (metric === "assessed_land_value") {
        return rollup.assessedLand;
      }
      if (metric === "assessed_building_value") {
        return rollup.assessedBuilding;
      }
      if (metric === "assessed_value_per_unit") {
        return rollup.units > 0 ? rollup.assessedTotal / rollup.units : 0;
      }
      return rollup.units;
    }

    function formatMetric(value: number, metric: string): string {
      if (metric.startsWith("assessed")) {
        return currencyFormatter.format(value);
      }
      return numberFormatter.format(value);
    }

    function escapeHtml(value: string): string {
      return value.replace(/[&<>"']/g, (character) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;"
      })[character] ?? character);
    }

    function rowMatchesUnitBasis(row: ExplorerRow, basis: string): boolean {
      if (!basis) {
        return true;
      }
      if (basis === "unknown") {
        return row.unit_count_confidence === "Not listed";
      }
      if (basis === "reported") {
        return row.unit_count_confidence === "reported";
      }
      return row.unit_count_confidence.startsWith("inferred");
    }

    function getRollups() {
      const group = String(groupSelect?.value || "ward") as keyof ExplorerRow;
      const scope = String(scopeSelect?.value || "current");
      const basis = String(unitBasisSelect?.value || "");
      const rollups = new Map<string, Rollup>();

      for (const row of rows) {
        if (scope === "current" && !row.is_current) {
          continue;
        }
        if (!rowMatchesUnitBasis(row, basis)) {
          continue;
        }
        const groupValue = String(row[group] || "Not listed");
        const rollup = rollups.get(groupValue) ?? {
          group: groupValue,
          properties: 0,
          units: 0,
          assessedTotal: 0,
          assessedLand: 0,
          assessedBuilding: 0
        };
        rollup.properties += 1;
        rollup.units += row.unit_count ?? 0;
        rollup.assessedTotal += row.assessed_total_value ?? 0;
        rollup.assessedLand += row.assessed_land_value ?? 0;
        rollup.assessedBuilding += row.assessed_building_value ?? 0;
        rollups.set(groupValue, rollup);
      }

      const metric = String(metricSelect?.value || "unit_count");
      return Array.from(rollups.values()).sort((left, right) =>
        metricValue(right, metric) - metricValue(left, metric)
        || left.group.localeCompare(right.group, "en-US", { numeric: true, sensitivity: "base" })
      );
    }

    function renderExplorer() {
      const metric = String(metricSelect?.value || "unit_count");
      const rollups = getRollups();
      const maxMetric = Math.max(...rollups.map((rollup) => metricValue(rollup, metric)), 0);

      if (status) {
        status.textContent = `${numberFormatter.format(rollups.length)} groups`;
      }

      if (tableBody) {
        tableBody.innerHTML = "";
        for (const rollup of rollups) {
          const row = document.createElement("tr");
          row.innerHTML = `
            <td class="px-4 py-3 font-semibold">${escapeHtml(rollup.group)}</td>
            <td class="px-4 py-3">${numberFormatter.format(rollup.properties)}</td>
            <td class="px-4 py-3">${numberFormatter.format(rollup.units)}</td>
            <td class="px-4 py-3">${currencyFormatter.format(rollup.assessedTotal)}</td>
            <td class="px-4 py-3">${rollup.units > 0 ? currencyFormatter.format(rollup.assessedTotal / rollup.units) : "Not listed"}</td>
          `;
          tableBody.append(row);
        }
      }

      if (bars) {
        bars.innerHTML = "";
        for (const rollup of rollups.slice(0, 12)) {
          const value = metricValue(rollup, metric);
          const width = maxMetric > 0 ? Math.max(4, Math.round((value / maxMetric) * 100)) : 0;
          const item = document.createElement("div");
          item.className = "grid gap-1";
          item.innerHTML = `
            <div class="flex items-baseline justify-between gap-3 text-sm">
              <span class="font-semibold">${escapeHtml(rollup.group)}</span>
              <span class="text-ink/65">${formatMetric(value, metric)}</span>
            </div>
            <div class="h-3 overflow-hidden rounded bg-paper">
              <div class="h-full bg-civic-green" style="width: ${width}%"></div>
            </div>
          `;
          bars.append(item);
        }
      }
    }

    groupSelect?.addEventListener("change", renderExplorer);
    metricSelect?.addEventListener("change", renderExplorer);
    scopeSelect?.addEventListener("change", renderExplorer);
    unitBasisSelect?.addEventListener("change", renderExplorer);
    renderExplorer();
  </script>
</Layout>
