---
import Layout from "@components/Layout.astro";
import DataSubnav from "@components/DataSubnav.astro";
import {
  formatChangeEventType,
  formatGeneratedAt,
  getChangelog,
  getProperties,
  getPropertyHref
} from "@lib/properties";
import { withBasePath } from "@lib/urls";

const changelog = await getChangelog();
const properties = await getProperties();
const propertyById = new Map(properties.map((property) => [property.property_id, property]));
---

<Layout title="Property Characteristics Changes | Minneapolis Public Housing Explorer" description="Owner, taxpayer, classification, and unit-count changes found in public records.">
  <section class="border-b border-line bg-paper">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase tracking-normal text-civic-green">Data audit view</p>
      <h1 class="mt-3 text-3xl font-bold">Property Characteristics Changes</h1>
      <p class="mt-3 max-w-3xl text-ink/70">
        Review owner, taxpayer, classification, and unit-count changes found in public records over time.
      </p>
      <p class="mt-3 text-sm font-semibold text-ink/65">
        {changelog.changes.length.toLocaleString()} events | Updated {formatGeneratedAt(changelog.generated_at)}
      </p>
    </div>
  </section>

  <DataSubnav active="changes" />

  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      {changelog.changes.length > 0 ? (
        <ol class="grid gap-4">
          {changelog.changes.map((change) => {
            const linkedProperty = propertyById.get(change.property_id);
            return (
              <li class="rounded border border-line bg-paper p-4">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <h2 class="font-bold">{change.event_date}: {formatChangeEventType(change.event_type)}</h2>
                  <a class="text-sm font-bold text-civic-green underline decoration-civic-leaf decoration-2 underline-offset-4" href={linkedProperty ? getPropertyHref(linkedProperty) : withBasePath("/properties/")}>
                    {linkedProperty?.canonical_address || change.property_id}
                  </a>
                </div>
                {(change.old_value || change.new_value) && (
                  <p class="mt-2 text-sm text-ink/65">
                    {change.old_value || "Not listed"} to {change.new_value || "Not listed"}
                  </p>
                )}
              </li>
            );
          })}
        </ol>
      ) : (
        <div class="rounded border border-line bg-paper p-6">
          <h2 class="text-xl font-bold">No changes are currently published</h2>
          <p class="mt-2 text-ink/70">
            Check back after the next data update.
          </p>
        </div>
      )}
    </div>
  </section>
</Layout>
